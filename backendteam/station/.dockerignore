# /station/.dockerignore

# NEVER copy local node_modules (this prevents the caching headache we just fixed!)
node_modules/
npm-debug.log

# Ignore local build outputs
dist/
dist-ssr/
build/

# Ignore environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore git history
.git/
.gitignore

# Ignore IDE and OS files
.vscode/
.idea/
.DS_Store